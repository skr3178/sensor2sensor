# Local dataset symlinks (huge nuScenes data, not for the repo).
# Both the original top-level symlink and the s2s_min_2 copies point at the
# same external dataset root and would otherwise be committed as broken refs.
/nuscenes
s2s_min_multi_cam/nuscenes
s2s_min_multi_cam/data/nuscenes_root

# Waymo Open Dataset sample (~586 MB) — kept locally only
s2s_min/data/waymo_sample/
# Waymo Open Dataset v2.0.1 (LiDAR-only download) — multi-GB, local only
s2s_min/data/waymo/
# Optional packed float16 memmap (produced by scripts/preprocess_waymo_to_memmap.py)
s2s_min/data/waymo_packed/
# Per-run training logs we don't need under git (size + churn)
s2s_min/out/train_vae_waymo_*.log

# Pretrained model binaries (kept locally; re-downloadable via
# s2s_min/scripts/download_image_vae.py). The folder layout + README + the small
# config.json files stay tracked so a fresh clone is self-documenting.
s2s_min/checkpoints/**/*.safetensors
s2s_min/checkpoints/**/*.bin
s2s_min/checkpoints/**/*.pt
s2s_min/checkpoints/.cache/

# Trained LiDAR VAE / U-Net checkpoints (regenerated by training runs)
s2s_min/out/*.pt
s2s_min/out/*.safetensors

# Cached VAE latents (regenerable via scripts/cache_latents.py)
s2s_min/out/cached_latents/

# Per-run training output (checkpoints + tensorboard, regenerable)
s2s_min/out/runs/
s2s_min/out/latest_run

# Transient process / scratch files
s2s_min/out/*.pid
/todo

# ── s2s_min_multi_cam/ mirrors the same patterns as s2s_min/ above ──
# Big binary weights (re-downloadable / regenerable):
s2s_min_multi_cam/checkpoints/**/*.safetensors
s2s_min_multi_cam/checkpoints/**/*.bin
s2s_min_multi_cam/checkpoints/**/*.pt
s2s_min_multi_cam/checkpoints/.cache/
# Trained / smoke-test checkpoints:
s2s_min_multi_cam/out/*.pt
s2s_min_multi_cam/out/*.safetensors
# Cached VAE latents:
s2s_min_multi_cam/out/cached_latents/
# Per-run training output:
s2s_min_multi_cam/out/runs/
s2s_min_multi_cam/out/latest_run
s2s_min_multi_cam/out/*.log
s2s_min_multi_cam/out/*.pid
# Local Waymo data (if/when copied over):
s2s_min_multi_cam/data/waymo/
s2s_min_multi_cam/data/waymo_packed/
s2s_min_multi_cam/data/waymo_sample/

# Claude Code local state
/.claude/

# MVDream local clone (kept locally, not pushed)
Reference_code/MVDream/

# RangeLDM local clone (kept locally, not pushed)
Reference_code/RangeLDM/

# light-field-networks local clone (kept locally, not pushed)
Reference_code/light-field-networks/

# LiDAR-Diffusion local clone (kept locally, not pushed)
Reference_code/LiDAR-Diffusion/

# Pytorch-UNet local clone (kept locally, not pushed)
Reference_code/Pytorch-UNet/

# diffusers local clone (kept locally, not pushed)
Reference_code/diffusers/

# guided-diffusion local clone (kept locally, not pushed)
Reference_code/guided-diffusion/

# Reference paper PDFs (kept locally, not pushed)
Reference_code/**/*.pdf

# Reference_code/X-Drive is a git submodule (yichen928/X-Drive)

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/

